from sentence_transformers import SentenceTransformer
import numpy as np

model = SentenceTransformer('all-MiniLM-L6-v2')

sentences = [
    "How do I reverse a linked list",
    "Reversing a linked list in Python",      # similar meaning
    "What is photosynthesis",      # different meaning
]

embeddings = model.encode(sentences)

# Calculate similarity between sentence 0 and others
def cosine_similarity(a, b):
    return np.dot(a, b) / (np.linalg.norm(a) * np.linalg.norm(b))

sim1 = cosine_similarity(embeddings[0], embeddings[1])
sim2 = cosine_similarity(embeddings[0], embeddings[2])

print(f"'How do I reverse a linked list' vs 'Reversing a linked list in Python': {sim1:.3f}")
print(f"'How do I reverse a linked list' vs 'What is photosynthesis': {sim2:.3f}")